datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("VIEWER")
  isActive  Boolean  @default(true)
  records   Record[]
}

model Record {
  id          Int      @id @default(autoincrement())
  amount      Float
  type        String   
  category    String
  date        DateTime @default(now())
  description String?
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}